🔹 Q5: Which IP sent maximum bytes (single top attacker)
Get-Content firewall.log |
Where-Object { $_ -match "dstip=117.20.44.95" } |
ForEach-Object {
    $ip = ($_ -split "srcip=")[1].Split(" ")[0]
    $bytes = [int](($_ -split "sentbyte=")[1].Split(" ")[0])
    "$ip,$bytes"
} |
ConvertFrom-Csv -Header IP,Bytes |
Group-Object IP |
ForEach-Object {
    [PSCustomObject]@{
        IP = $_.Name
        TotalBytes = ($_.Group | Measure-Object Bytes -Sum).Sum
    }
} |
Sort-Object TotalBytes -Descending |
Select-Object -First 1

