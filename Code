Q1: Top 10 Source IP (max bytes → dstip 117.20.44.95)

Get-Content firewall.log |
Where-Object { $_ -match "dstip=117.20.44.95" } |
ForEach-Object {
    $ip = ($_ -split "srcip=")[1].Split(" ")[0]
    $bytes = [int](($_ -split "sentbyte=")[1].Split(" ")[0])
    "$ip,$bytes"
} |
ConvertFrom-Csv -Header IP,Bytes |
Group-Object IP |
ForEach-Object {
    $_.Name + " : " + ($_.Group | Measure-Object Bytes -Sum).Sum
} |
Sort-Object { [int]($_.Split(":")[1]) } -Descending |
Select-Object -First 10

